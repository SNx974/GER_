# ─── Base de données ───
# En local (Docker) : postgresql://ger:ger_password@localhost:5432/ger_esport?schema=public
# Sur Dokploy : coller l'"Internal Connection URL" fournie par le service Postgres
DATABASE_URL="postgresql://user:password@host:5432/db?schema=public"

# ─── NextAuth ───
# Générer un secret : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="change-me"
# En prod, mettre l'URL publique du déploiement (ex : https://ger.mondomaine.com)
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin initial (créé/mis à jour par le seed au démarrage) ───
ADMIN_EMAIL="admin@ger.gg"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Super Admin"

# ─── Analyse IA des résultats (reconnaissance d'image via Google Gemini) ───
# Clé : https://aistudio.google.com/apikey — sans clé, un repli heuristique est utilisé
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
